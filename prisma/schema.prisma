generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StoreCredential {
  id          String   @id @default(cuid())
  storeId     String   @unique
  accessToken String
  scope       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id            String   @id @default(cuid())
  storeId       String
  productId     String
  variantId     String
  sku           String?
  name          String
  categoria     String?
  costoUnitario Decimal? @db.Decimal(12, 2)
  precioVenta   Decimal? @db.Decimal(12, 2)
  activo        Boolean  @default(true)
  status        String   @default("pending_cost")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, variantId])
  @@index([storeId])
  @@index([status])
}

model PersonalProduct {
  id            String   @id @default(cuid())
  name          String
  categoria     String?
  costoUnitario Decimal? @db.Decimal(12, 2)
  precioVenta   Decimal? @db.Decimal(12, 2)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@index([activo])
}

model Order {
  id                         String      @id @default(cuid())
  orderId                    String
  storeId                    String
  customerName               String?
  subtotal                   Decimal?    @db.Decimal(12, 2)
  shippingCost               Decimal?    @db.Decimal(12, 2)
  shippingCostOwner          Decimal?    @db.Decimal(12, 2)
  shippingMethod             String?
  discount                   Decimal?    @db.Decimal(12, 2)
  total                      Decimal     @db.Decimal(12, 2)
  totalPaidByCustomer        Decimal?    @db.Decimal(12, 2)
  processingFee              Decimal?    @db.Decimal(12, 2)
  installmentsFee            Decimal?    @db.Decimal(12, 2)
  netTotal                   Decimal?    @db.Decimal(12, 2)
  currency                   String?
  paymentMethod              String?
  paymentGateway             String?
  cardBrand                  String?
  cardLastDigits             String?
  installments               Int?
  installmentsInterestFree   Boolean?
  transactionId              String?
  paymentStatus              String
  orderDate                  DateTime
  source                     String      @default("tiendanube")
  createdAt                  DateTime    @default(now())
  updatedAt                  DateTime    @updatedAt
  items                      OrderItem[]

  @@unique([storeId, orderId])
  @@index([storeId])
  @@index([orderDate])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderDbId String
  order     Order   @relation(fields: [orderDbId], references: [id], onDelete: Cascade)
  productId String
  variantId String
  sku       String?
  name      String
  categoria String?
  quantity  Int
  price     Decimal @db.Decimal(12, 2)

  @@index([orderDbId])
}
