generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StoreCredential {
  id          String   @id @default(cuid())
  storeId     String   @unique
  accessToken String
  scope       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id            String   @id @default(cuid())
  storeId       String
  productId     String
  variantId     String
  sku           String?
  name          String
  costoUnitario Decimal? @db.Decimal(12, 2)
  status        String   @default("pending_cost")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, variantId])
  @@index([storeId])
  @@index([status])
}

model Order {
  id            String      @id @default(cuid())
  orderId       String
  storeId       String
  customerName  String?
  total         Decimal     @db.Decimal(12, 2)
  paymentStatus String
  orderDate     DateTime
  source        String      @default("tiendanube")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]

  @@unique([storeId, orderId])
  @@index([storeId])
  @@index([orderDate])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderDbId String
  order     Order   @relation(fields: [orderDbId], references: [id], onDelete: Cascade)
  productId String
  variantId String
  sku       String?
  name      String
  quantity  Int
  price     Decimal @db.Decimal(12, 2)

  @@index([orderDbId])
}
